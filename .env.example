# Music Co-Pilot — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The app runs without an API key (local mode), but Teaching Agent
# and SE Agent API fallback require it for full quality.

# Anthropic API key — get one at https://console.anthropic.com/
# Without this key: Teaching Agent uses local templates, SE Agent
# has no API fallback for unrecognized topics. All other features work.
ANTHROPIC_API_KEY=your-key-here
